{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..", 
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverage": true,
  "collectCoverageFrom": [
    "src/**/*.(t|j)s",
    "!src/main.ts",
    "!src/**/*.module.ts",
    "!src/**/*.entity.ts",
    "!src/**/*.dto.ts"
  ],
  "coverageDirectory": "./coverage",
  "coverageReporters": ["text", "lcov"]
}
